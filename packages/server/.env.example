# ─── 服务器 ──────────────────────────────────────────────────────────────────
PORT=3300

# ─── 认证 ────────────────────────────────────────────────────────────────────
JWT_SECRET=zenith-admin-secret

# ─── 数据库（PostgreSQL）──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zenith_admin

# ─── Redis（会话持久化）────────────────────────────────────────────────────────
# 方式一：URL 格式（推荐，支持带密码的连接）
REDIS_URL=redis://127.0.0.1:6379
# 带密码示例：
# REDIS_URL=redis://:your_password@127.0.0.1:6379/0

# 方式二：逐项配置（与 REDIS_URL 二选一，REDIS_URL 优先）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_KEY_PREFIX=zenith:   # 所有 Redis key 的命名空间前缀（默认 zenith:）

# ─── 日志 ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILES=30d

# ─── 运行环境 ──────────────────────────────────────────────────────────────────
# 设置为 true 时，每个响应会附加 Server-Timing 头，可在 Chrome DevTools → Network → Timing 查看各阶段耗时
# 建议生产环境设为 false，避免暴露内部性能信息
SERVER_TIMING_ENABLED=false

# ─── 可观测性（Prometheus / OpenTelemetry）───────────────────────────────────
# Prometheus 指标默认暴露在 GET /metrics，无需额外配置。
# OpenTelemetry tracing：
# - OTEL_ENABLED=true 时强制启用
# - 若未显式设置 OTEL_ENABLED，但配置了 OTLP endpoint，也会自动启用
OTEL_ENABLED=false
OTEL_SERVICE_NAME=zenith-admin-server
# 可选：未设置时默认读取当前 npm package version
# OTEL_SERVICE_VERSION=0.5.0

# 可选：OTLP traces 专用 HTTP 导出地址（推荐）
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# 可选：通用 OTLP 端点（未设置 traces endpoint 时使用）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# 可选：OTLP 导出请求头，逗号分隔。
# 示例：OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xxx,x-honeycomb-team=xxx
# OTEL_EXPORTER_OTLP_HEADERS=

# ─── 请求限制 ──────────────────────────────────────────────────────────────────
# 请求体大小限制（单位：字节）。0 或未设置 = 不限制（使用运行时默认）
# 建议：普通 10MB=10485760；允许大文件上传设为 104857600（100MB）或更大
REQUEST_BODY_LIMIT=0

# 请求超时（单位：毫秒）。0 或未设置 = 不启用超时中间件
# 启用后自动排除：/api/ws、/api/files、/api/db-backups 及所有 /export 接口
REQUEST_TIMEOUT_MS=0

# ─── 安全 ────────────────────────────────────────────────────────────────────
# CSRF 允许的来源白名单，逗号分隔。留空 = 开发模式不限制来源
# 生产环境强烈建议配置，防止跨站请求伪造（CSRF）攻击
# 示例：ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com
ALLOWED_ORIGINS=
